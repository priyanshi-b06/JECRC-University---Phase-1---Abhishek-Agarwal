//Problem 5 
//Smart Ac remote // Function overloading // Default Arguments

#include <iostream>
using namespace std;

void setTemperature(int temp = 22){
    cout << "Temperature set to " << temp << "°C" << "\n";
}
void setTemperature(string mode) {
    if(mode == "ECO"){
        cout << "Temperature set to 24 °C" << "\n";
    } else if(mode == "TURBO") {
        cout << "Temperature set to 18 °C " << "\n";
    }
}

int main() {
    setTemprature() << "\n"; //default value -- 22
    setTemperature(20.5)  << "\n";  //manually setting the temperature
    setTemperature("ECO")  << "\n";  //set temprature to 24
    setTemperature("TURBO")  << "\n";  //setTemperature to 18
}

