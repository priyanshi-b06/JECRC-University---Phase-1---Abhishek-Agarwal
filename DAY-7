//Problem -- 3
//Pillar of OOPS
//Encapsulation
//Encapsulation means we are binding the data into a single unit (Functions, data, variables, methods)
//into a single unit called class and making some reactions on this clas members
//Data security
//controlled access over my Data 
//validation before accessing the Data 
//code maintainability

#include <iostream>
using namespace std;

class bankAccount{
private:
int balance;
public:
void setBalance(int amount) {
    if(amount >= 0) {
        balance = amount;
    } else {
        cout <<"Enter a valid Number...";
    }
}

int getbalance() {
    return balance;
    }
};
int main() {
    bankAccount obj1;
    obj1.setBalance(5000);
    cout << obj1.getbalance();
    return 0;
}
