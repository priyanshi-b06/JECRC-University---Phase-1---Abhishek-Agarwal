//Problem 1 
//Print the star pattern

#include <iostream>
using namespace std;
int main() {
//print upper right angle triangle
    int n;
    cin>>n;
    
    for(int i=1;i<=n;i++){
        for(int j=1;j<=i;j++){
            cout<<"*";
        }
        cout << "\n";
    }
//print lower triangle
    for(int i = n-1; i >= 1; i--) 
    {
        for(int j = 1;j <= i;j++)
        {
            cout << "*";
        }
        cout << "\n";
    }
}

