Problem 3 
Print a right angle triangle

#include <iostream>
using namespace std;

int main() {
    int n;
    cin >> n;
    for(int i=1;i<=n;i++){
        for(int j=1;j<=i;j++){
            cout<<"*";
        }
        cout<<"\n";
    }
}  

Problem 4 
To print the mirror of right angle triangle
#include <iostream>
using namespace std;

int main(){
    int n;
    cin >> n;
    for(int i=1;i<n;i++) {
        for(int j=1;j<=n-i;j++) {
            cout << " ";
        }
        for(int k=1;k<=i;k++) {
            cout << "*";
        }
        cout << endl;
    }
    return 0;
 
}

